<?xml version="1.0" encoding="UTF-8"?>

<plugins xmlns="urn:org.androidaudioplugin.core">
  <plugin name="Aelapse" category="Effect"
      developer="smiarx / AAP Porting Project" unique-id="juceaap:aelapse" library="libAelapse_Standalone.so"
      entrypoint="GetJuceAAPFactoryStandalone"
      gui:ui-view-factory="org.androidaudioplugin.juce.JuceAudioPluginViewFactory"
      xmlns:gui="urn://androidaudioplugin.org/extensions/gui">
    <extensions bom="v0.12.0" />
    <ports>
      <port direction="output" content="audio" name="Left"/>
      <port direction="output" content="audio" name="Right"/>
      <port direction="input" content="audio" name="Left"/>
      <port direction="input" content="audio" name="Right"/>
      <port direction="input" content="midi2" name="MIDI input"/>
      <port direction="output" content="midi2" name="MIDI output"/>
    </ports>
  </plugin>
</plugins>
