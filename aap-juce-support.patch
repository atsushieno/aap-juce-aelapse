diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7123520..d8d4487 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -9,21 +9,67 @@ set(COMPANY_NAME "S-audio")
 
 set(CMAKE_INTERPROCEDURAL_OPTIMIZATION_RELEASE TRUE)
 
-find_package(JUCE CONFIG QUIET)
+# AAP: never use a pre-installed JUCE package (upstream's find_package
+# escape hatch) - the AAP build requires the patched JUCE below.
+set(JUCE_FOUND FALSE)
 if(NOT ${JUCE_FOUND})
-    Include(FetchContent)
-
-    FetchContent_Declare(
-      JUCE
-      GIT_REPOSITORY https://github.com/juce-framework/JUCE
-      GIT_TAG        7.0.12
+    # AAP: import JUCE via CPM instead of plain FetchContent, applying the
+    # AAP JUCE patches as part of the population. With CPM_SOURCE_CACHE the
+    # patched source is shared by all build directories (e.g. per-ABI Android
+    # builds) without re-applying the patches, and CUSTOM_CACHE_KEY keeps the
+    # cached path deterministic (app/build.gradle compiles the patched JUCE
+    # Java sources from there - keep them in sync).
+    include(${AAP_JUCE_DIR}/cmake/CPM.cmake)
+
+    # PATCH_COMMAND with git apply, instead of CPM's own PATCHES: `patch`
+    # may not be available on Windows, and --ignore-space-change is needed
+    # for the patches to apply onto the CRLF sources in the JUCE repo.
+    CPMAddPackage(
+      NAME             JUCE
+      GIT_REPOSITORY   https://github.com/juce-framework/JUCE
+      GIT_TAG          7.0.12
+      CUSTOM_CACHE_KEY aap-7.0.12
+      PATCH_COMMAND    git apply --ignore-space-change ${AAP_JUCE_DIR}/juce-patches/7.0.12/disable-cgwindowlistcreateimage.patch
+      COMMAND          git apply --ignore-space-change ${AAP_JUCE_DIR}/juce-patches/7.0.6/support-plugin-ui.patch
+      COMMAND          git apply --ignore-space-change ${AAP_JUCE_DIR}/juce-patches/7.0.11/juce-component-peer-view-touch.patch
+      COMMAND          git apply --ignore-space-change ${AAP_JUCE_DIR}/juce-patches/7.0.12/popup-menu-android.patch
+      COMMAND          git apply --ignore-space-change ${AAP_JUCE_DIR}/JUCE-support-Android-CMake.patch
     )
-    FetchContent_MakeAvailable(JUCE)
+
+    # Guard against a stale source cache entry (e.g. after the patch set
+    # changed without changing CUSTOM_CACHE_KEY).
+    file(READ "${JUCE_SOURCE_DIR}/modules/juce_gui_basics/native/java/app/com/rmsl/juce/ComponentPeerView.java" _AAP_JUCE_PATCH_PROBE)
+    if(NOT _AAP_JUCE_PATCH_PROBE MATCHES "getLocationOnScreen")
+        message(FATAL_ERROR
+            "JUCE source cache is stale or patch application failed: ${JUCE_SOURCE_DIR}\n"
+            "Remove that directory and reconfigure.")
+    endif()
+
+    # Expose the patched JUCE tree at the conventional in-tree location
+    # (the Android Gradle build compiles JUCE's Java sources from it). This
+    # works wherever the population went, with or without CPM_SOURCE_CACHE.
+    if(NOT "${CMAKE_CURRENT_SOURCE_DIR}/modules/juce" STREQUAL "${JUCE_SOURCE_DIR}")
+        file(MAKE_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/modules")
+        file(REMOVE "${CMAKE_CURRENT_SOURCE_DIR}/modules/juce")
+        file(CREATE_LINK "${JUCE_SOURCE_DIR}" "${CMAKE_CURRENT_SOURCE_DIR}/modules/juce"
+             SYMBOLIC RESULT _AAP_JUCE_LINK_RESULT)
+        # The result is only advisory (a concurrent configuration may have
+        # just (re-)created the same link); what matters is that it resolves.
+        if(NOT EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/modules/juce/CMakeLists.txt")
+            message(FATAL_ERROR
+                "Could not link modules/juce to the JUCE tree (${_AAP_JUCE_LINK_RESULT})")
+        endif()
+    endif()
 endif()
 
-set(JUCE_FORMATS VST3 AU)
+if(ANDROID)
+    # AAP loads the plugin via the Standalone target (GetJuceAAPFactoryStandalone).
+    set(JUCE_FORMATS "")
+else()
+    set(JUCE_FORMATS VST3 AU)
+endif()
 # Build LV2 only on Linux
-if(UNIX AND NOT APPLE)
+if(UNIX AND NOT APPLE AND NOT ANDROID)
     message(STATUS "Building LV2 plugin format")
     list(APPEND JUCE_FORMATS LV2)
 endif()
@@ -40,10 +86,14 @@ juce_add_plugin(${PROJECT_NAME}
     PLUGIN_CODE Aeth
     LV2URI https://github.com/smiarx/aelapse
 
-    FORMATS VST3 ${JUCE_FORMATS}
+    FORMATS Standalone ${JUCE_FORMATS}
     PRODUCT_NAME "${PROJECT_NAME}")
 
 # tests
+if(ANDROID)
+    # No tests (nor their Catch2 fetch) in the Android plugin build.
+    set(BUILD_TESTING OFF CACHE BOOL "" FORCE)
+endif()
 include(CTest)
 option(BUILD_TESTING "Build tests" ON)
 if (BUILD_TESTING)
@@ -103,3 +153,38 @@ target_link_libraries(${PROJECT_NAME}
         juce::juce_recommended_config_flags
         juce::juce_recommended_warning_flags
     )
+
+# begin AAP specifics -->
+
+juce_add_modules(${AAP_JUCE_DIR}/aap-modules/aap_audio_processors)
+
+# They are needed in desktop builds too, for generate-aap-metadata.
+target_include_directories(${PROJECT_NAME} PUBLIC
+        "${AAP_DIR}/include"
+        "${AAP_JUCE_DIR}/aap-modules"
+)
+
+target_compile_definitions(${PROJECT_NAME} PUBLIC
+        JUCEAAP_HAVE_AUDIO_PLAYHEAD_NEW_POSITION_INFO=1
+        JUCE_PUSH_NOTIFICATIONS=1
+        JUCE_PUSH_NOTIFICATIONS_ACTIVITY="com/rmsl/juce/JuceActivity"
+)
+
+message("AAP_DIR: ${AAP_DIR}")
+message("AAP_JUCE_DIR: ${AAP_JUCE_DIR}")
+
+if (ANDROID)
+    add_compile_definitions(
+            [[JUCE_ANDROID=1]]
+            [[JUCE_DONT_AUTO_OPEN_MIDI_DEVICES_ON_MOBILE=1]]
+    )
+
+    find_package(androidaudioplugin REQUIRED CONFIG)
+    target_link_libraries(${PROJECT_NAME} PRIVATE
+            androidaudioplugin::androidaudioplugin
+    )
+endif (ANDROID)
+
+target_link_libraries(${PROJECT_NAME} PRIVATE aap_audio_processors)
+
+# <-- end AAP specifics
